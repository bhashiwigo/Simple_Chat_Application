<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="550.0" prefWidth="500.0" styleClass="root-pane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.controller.ClientFormController">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    <children>
        <VBox alignment="CENTER" layoutX="20.0" layoutY="20.0" prefHeight="510.0" prefWidth="460.0" styleClass="glass-card" spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <VBox alignment="CENTER_LEFT" spacing="5.0">
                    <children>
                        <Label styleClass="title-label" text="CYBER CHAT // CLIENT" />
                        <Label fx:id="lblStatus" styleClass="status-label" text="Connecting to network..." />
                    </children>
                </VBox>
                <TextArea fx:id="txtChatArea" editable="false" focusTraversable="false" prefHeight="380.0" prefWidth="410.0" styleClass="custom-text-area" wrapText="true" VBox.vgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <TextField fx:id="txtMessage" onAction="#txtMessageOnAction" prefHeight="40.0" promptText="Enter transmission data..." styleClass="custom-text-field" HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnSend" mnemonicParsing="false" onAction="#btnSendOnAction" prefHeight="40.0" styleClass="btn-send" text="SEND" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
